{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LLM Translator",
  "version": "0.1.0",
  "identifier": "com.sakayori.llmtranslator",
  "build": {
    "frontendDist": "../../../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LLM Translator",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Local LLM translation workspace",
    "category": "Productivity",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
